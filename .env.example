# ── Anthropic Claude API ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3000

# ── Segurança ─────────────────────────────────────────────────────────────────
DASHBOARD_PASSWORD=sua_senha_forte_aqui

# ── Identidade editorial ──────────────────────────────────────────────────────
BRAND_NAME=Acrópole
BRAND_HANDLE_X=@acropole

# ── Tom dos posts (informativo | opinativo | urgente | irônico) ───────────────
POST_TONE=opinativo

# ── Voz editorial (acropole | intercept | folha) ──────────────────────────────
# acropole  → analítico, autoridade, sem militância mas com perspectiva
# intercept → crítico, foca em conflito de interesses e poder real
# folha     → jornalístico clássico, denso em dados, colunista de referência
EDITORIAL_VOICE=acropole
